# Auto Sentinel local secrets — copy to .env and fill in real values.
# .env is gitignored; never commit it.

# Volcano Ark — single key for ALL access points (Doubao + GLM-4.7).
# Used by Diagnosis/CodeFixer/InfraSRE/Supervisor (Doubao) AND SecurityReviewer
# (GLM-4.7). GLM-4.7 is proxied through the same Ark gateway, so there is no
# separate GLM_API_KEY anymore — the `glm` endpoint in config/model_routing.yaml
# also references ARK_API_KEY.
ARK_API_KEY=your_volcano_ark_key_here

# Optional: override Sprint 5 budget cap (default 20.6 USD = ¥150)
# AUTOSENTINEL_BUDGET_LIMIT_USD=20.6
