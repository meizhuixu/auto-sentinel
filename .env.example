# Auto Sentinel local secrets — copy to .env and fill in real values.
# .env is gitignored; never commit it.

# Volcano Ark (Doubao) — used by Diagnosis/CodeFixer/InfraSRE/Supervisor
ARK_API_KEY=your_volcano_ark_key_here

# Zhipu GLM-4.7 — used by SecurityReviewer (PR-3 unused, fill before PR-4 if needed)
GLM_API_KEY=your_zhipu_glm_key_here

# Optional: override Sprint 5 budget cap (default 20.6 USD = ¥150)
# AUTOSENTINEL_BUDGET_LIMIT_USD=20.6
